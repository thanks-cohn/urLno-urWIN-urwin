{
  "manifest_version": 3,
  "name": "Source Page Metadata",
  "version": "1.0.0",
  "description": "Attaches the exact webpage that initiated each download to the completed file.",
  "key": "",
  "permissions": [
    "alarms",
    "downloads",
    "nativeMessaging",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Source Page Metadata",
    "default_popup": "popup.html"
  }
}
